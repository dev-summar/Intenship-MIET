# ---------------------------------------------------------------------------
# SPA (Single Page Application) routing for React/Vite with React Router
# ---------------------------------------------------------------------------
#
# Why this is needed:
# In an SPA, the entire app is loaded from index.html. React Router handles
# navigation in the browser without requesting new pages from the server.
# When a user refreshes the page or opens a direct link (e.g. /teachers,
# /dashboard, /students), Apache receives a request for that path. Without
# this config, Apache looks for a real file or folder at that path, finds
# nothing, and returns 404. This rewrite sends all such requests to
# index.html so the React app can load and React Router can match the URL
# and render the correct view.
#
# ---------------------------------------------------------------------------

RewriteEngine On
RewriteBase /

# If request is not a real file
RewriteCond %{REQUEST_FILENAME} !-f

# If request is not a real directory
RewriteCond %{REQUEST_FILENAME} !-d

# Redirect all requests to index.html
RewriteRule ^ index.html [L]
